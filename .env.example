NODE_ENV=production
BACKEND_PORT=3100

POSTGRES_APP_DB=tiki_app
POSTGRES_APP_USER=tiki_app
POSTGRES_APP_PASSWORD=

POSTGRES_KEYCLOAK_DB=tiki_keycloak
